# =============================================================================
# Zoom App credentials (from your Zoom Marketplace dev account)
# =============================================================================
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET=

# Must match the redirect URL configured in the Zoom app
ZOOM_REDIRECT_URI=https://your-domain.vercel.app/api/oauth/callback

# =============================================================================
# Database (Postgres) — get from Neon dashboard
# =============================================================================
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# =============================================================================
# Token encryption key — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# =============================================================================
TOKEN_ENCRYPTION_KEY=

# =============================================================================
# Public URL of this app
# =============================================================================
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
