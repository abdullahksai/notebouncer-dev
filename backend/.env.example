# =============================================================================
# Database (Postgres) — get from Neon dashboard
# =============================================================================
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# =============================================================================
# Token encryption key — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# =============================================================================
TOKEN_ENCRYPTION_KEY=

# =============================================================================
# Zoom Marketplace credentials
# =============================================================================
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET=

# Must match the OAuth Redirect URL in your Zoom Marketplace app config.
# Point this at the BACKEND, not the frontend.
ZOOM_REDIRECT_URI=http://localhost:4000/oauth/callback

# =============================================================================
# Frontend URL — where to bounce the user after OAuth completes.
# =============================================================================
FRONTEND_URL=http://localhost:3000

# =============================================================================
# Server config
# =============================================================================
PORT=4000
NODE_ENV=development
