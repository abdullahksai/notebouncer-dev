# =============================================================================
# Backend API URL — used by the browser (sidebar) for fetch calls.
# =============================================================================
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Optional: server-side fetch URL used by the dashboard RSC. Defaults to
# NEXT_PUBLIC_BACKEND_URL if unset. Override when the backend is reachable
# at a different hostname from the frontend's server (e.g. internal LB).
# BACKEND_INTERNAL_URL=http://localhost:4000

# =============================================================================
# Public URL of this frontend (used in metadata/OG tags). Optional.
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
