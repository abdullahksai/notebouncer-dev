{
  "name": "notebouncer",
  "version": "0.3.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n fe,be -c blue,yellow \"npm:dev -w frontend\" \"npm:dev -w backend\"",
    "build": "npm run build -w backend && npm run build -w frontend",
    "start": "concurrently -n fe,be -c blue,yellow \"npm:start -w frontend\" \"npm:start -w backend\"",
    "db:push": "npm run db:push -w backend",
    "db:studio": "npm run db:studio -w backend",
    "lint": "npm run lint -w frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
